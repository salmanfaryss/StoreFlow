@using StoreFlow.Models.LINQ_Siniflari
@model List<CustomerCountByCityViewModel>
@{
    ViewData["Title"] = "CustomerCountyCity";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Müşteri Listesi</h3>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Şehir Adi</th>
                                <th>Müşteri Sayısı</th>
                               
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <th>@count</th>
                                    <td>@item.City</td>
                                    <td>@item.CustomerCount</td>
         
                                </tr>
                            }

                        </tbody>
                    </table>
                    <a href="/Customer/CreateCustomer/" class="btn btn-outline-primary">Yeni Müşteri Girişi</a>
                </div>
            </div>
        </div>
    </div>
</div>
